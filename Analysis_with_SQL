CREATE DATABASE CHOCOLATE 

USE CHOCOLATE

SELECT * FROM Chocolate_sales


--Total Number of Orders
SELECT COUNT(*) 
FROM Chocolate_Sales;


---Total Number of Products
SELECT DISTINCT PRODUCT 
FROM Chocolate_Sales


---Total Number of Countries
SELECT DISTINCT Country 
FROM Chocolate_Sales


--TOTAL REVENUE GENERATED
SELECT ROUND(SUM(Price_per_box * boxes_shipped), 2) as Total_Revenue 
from Chocolate_Sales


--AVERAGE REVENUE PER ORDER 
SELECT ROUND(AVG(AMOUNT), 2) as AVERATE_REVENUE_GENERATED
FROM Chocolate_Sales


--HIGHEST ORDER 
SELECT MAX(AMOUNT) 
FROM Chocolate_Sales


--HIGHEST ORDER 
SELECT TOP 10 AMOUNT
FROM Chocolate_Sales
ORDER BY AMOUNT DESC 


--REVENUE GENERATED BY EACH PRODUCT
SELECT PRODUCT, SUM(PRICE_PER_BOX) AS SUM
FROM Chocolate_Sales
GROUP BY PRODUCT
ORDER BY SUM DESC


--REVENUE GENERATED BY COUNTRY
SELECT COUNTRY, ROUND(SUM(PRICE_PER_BOX),2) AS SUM
FROM Chocolate_Sales
GROUP BY COUNTRY
ORDER BY SUM DESC


--REVENUE GENERATED BY SALES CHANNEL
SELECT Channel, ROUND(SUM(PRICE_PER_BOX),2) AS SUM
FROM Chocolate_Sales
GROUP BY CHannel
ORDER BY SUM DESC

--REVENUE GENERATED BY SALES CHANNEL
SELECT Salesperson, ROUND(SUM(PRICE_PER_BOX),2) AS SUM
FROM Chocolate_Sales
GROUP BY salesperson
ORDER BY SUM DESC


--BEST SELLING PRODUCT BY REVENUE
SELECT TOP 1 Product, Total_Revenue
FROM
(
    SELECT Product,
           ROUND(SUM(Price_per_Box * Boxes_Shipped), 2) AS Total_Revenue
    FROM Chocolate_Sales
    GROUP BY Product
) AS T
ORDER BY Total_Revenue DESC;



--BEST SELLING PRODUCT BY BOX SHIPPED 
SELECT top 1 product, SUM(BOXES_SHIPPED) as Highest_Box_Shipped
FROM Chocolate_Sales
GROUP BY Product

--Average price per box for each product
SELECT PRODUCT, ROUND(AVG(Price_per_box),2) AS AVERAGE_PRICE 
FROM Chocolate_sales
GROUP BY Product
ORDER BY Product desc


--WHICH COUNTRY GENERATED THE HIGHEST REVENUE 
SELECT TOP 1 COUNTRY, ROUND(SUM(AMOUNT),2) AS REVENUE 
FROM Chocolate_Sales
GROUP BY COUNTRY
ORDER BY COUNTRY DESC;

--AVERAGE DISCOUNT PERCENTAGE 
SELECT ROUND(AVG(Discount_pct),2) as Average_Discount_Percentage
from chocolate_sales


--REVENUE GENERATED PER YEAR 
SELECT Year(Order_Date) as Sales_Year,
ROUND(SUM(AMOUNT),2)
from Chocolate_Sales
GROUP BY Year(Order_Date)
ORDER BY SALES_YEAR DESC


--REVENUE GENERATED PER MONTH 
SELECT Year(Order_Date) as Sales_Year,
Month(Order_Date) as Sales_Month,
ROUND(SUM(AMOUNT),2) as Monthly_Sales_Amount
from Chocolate_Sales
GROUP BY Year(Order_Date), Month(Order_Date)
ORDER BY SALES_YEAR DESC


--TOP 5 PRODUCTS BY REVENUE 
SELECT top 5 Product, Sum(Amount) as Revenue
from Chocolate_Sales
GROUP BY Product 
Order By Revenue Desc


